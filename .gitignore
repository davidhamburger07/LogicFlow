# ── LOGICFLOW ────────────────────────────────────────────────
# Plain ES-module project, no build step. Keep the source; ignore
# local/dev cruft so the repo stays clean for GitHub.

# Dev / QA screenshots (generated locally by the screenshot workflow)
temporary screenshots/

# Ad-hoc verification & capture scripts (temporary, deleted after use)
verify_*.mjs
capture_*.mjs
debug_*.mjs

# Dev server log (node serve.mjs > server.log)
server.log

# Stray accidental files — safe to delete from disk too (see note)
# /LogicFlow/ is an empty nested git repo from an accidental `git init`
# /3.11 is stray `uvx` help text saved to a file
/LogicFlow/
/3.11





# Node / package managers
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnp.*

# Environment / secrets
.env
.env.*
!.env.example

# Editors / IDEs
.vscode/
.idea/
*.sublime-workspace
*.swp
*.swo
*~

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
